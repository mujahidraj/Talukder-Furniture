# Backend Environment Variables

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/talukder_furniture

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-generate-with-openssl-rand-hex-64
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-generate-with-openssl-rand-hex-64
JWT_REFRESH_EXPIRES_IN=30d

# Password Hashing
BCRYPT_SALT_ROUNDS=10

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Admin Seed Account
ADMIN_SEED_EMAIL=admin@talukder-furniture.com
ADMIN_SEED_PASSWORD=Admin@123456

# File Storage (local | s3)
UPLOAD_DRIVER=local
UPLOAD_LOCAL_PATH=./uploads

# S3-Compatible Storage (only if UPLOAD_DRIVER=s3)
S3_BUCKET_NAME=
S3_REGION=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_PUBLIC_BASE_URL=

# SMTP Email (optional — notifications deferred to Phase 8)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
ADMIN_NOTIFY_EMAIL=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
